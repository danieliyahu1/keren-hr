# ==============================================================================
# OpenCode — headless server
#
# Runs `opencode serve` on port 4096.
# Stateless: receives prompts over HTTP from the kerenhr service and responds.
# ==============================================================================
FROM node:lts-slim

# Install system dependencies for Playwright browsers
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    xauth dbus-x11 \
    && rm -rf /var/lib/apt/lists/*

# Install opencode globally
RUN npm install -g opencode-ai

# Pre-install Playwright MCP and bake Chromium into the image
# PLAYWRIGHT_BROWSERS_PATH keeps browsers outside the home dir so they
# survive user switching and are not accidentally bind-mounted over.
ENV PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
RUN npx -y @playwright/mcp@latest --version \
    && npx -y playwright install --with-deps chromium

# Create a non-root user
RUN groupadd -r opencode && useradd -r -g opencode -d /home/opencode opencode \
    && mkdir -p /home/opencode/.config/opencode \
    && mkdir -p /home/opencode/.playwright-mcp \
    && mkdir -p /home/opencode/.playwright-mcp-output \
    && chown -R opencode:opencode /home/opencode \
    && chown -R opencode:opencode /ms-playwright

# Bake the opencode config with Playwright MCP enabled
COPY opencode-container.json /home/opencode/.config/opencode/opencode.json
RUN chown opencode:opencode /home/opencode/.config/opencode/opencode.json

# Copy entrypoint script
COPY opencode/docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

USER opencode

EXPOSE 4096

ENTRYPOINT ["/usr/local/bin/docker-entrypoint.sh"]
