{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": {
      "*": "deny",
      ".opencode/skills/*": "allow"
    },
    "edit": {
      "*": "deny",
      ".opencode/skills/*": "allow"
    },
    "glob": {
      "*": "deny",
      ".opencode/skills/*": "allow"
    },
    "list": {
      "*": "deny",
      ".opencode/skills": "allow",
      ".opencode/skills/*": "allow"
    },
    "bash": "deny"
  },
  "mcp": {
    "reddit": {
      "type": "local",
      "command": ["npx", "-y", "reddit-mcp-buddy"],
      "enabled": true
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    }
  }
}
